APP_NAME=MemberMD
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (PostgreSQL) ───────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=membermd
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Session ─────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# For production: add Redis plugin in Railway, then set:
# CACHE_STORE=redis
# REDIS_URL=redis://default:xxx@redis.railway.internal:6379

# ─── Twilio (SMS) ────────────────────────────────────────────────
# Auth Token also verifies inbound webhook signatures — keep secret.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Stripe Connect — separate webhook secret for /api/webhooks/stripe/connect
STRIPE_CONNECT_WEBHOOK_SECRET=
# Optional overrides; default to APP_URL + frontend route
STRIPE_CONNECT_RETURN_URL=
STRIPE_CONNECT_REFRESH_URL=

# ─── Resend (Email) ─────────────────────────────────────────────
RESEND_API_KEY=
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@membermd.io"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Frontend URL (CORS) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Daily.co (Telehealth — Phase 2) ────────────────────────────
DAILY_API_KEY=

# ─── SRFax (eFax) ─────────────────────────────────────────────────
SRFAX_ACCESS_ID=
SRFAX_ACCESS_PWD=
SRFAX_CALLER_ID=
SRFAX_SENDER_EMAIL=

# ─── Sentry (Error Tracking) ──────────────────────────────────────
# Required to enable error capture. Get the DSN from sentry.io →
# Project → Client Keys (DSN). Empty value = Sentry disabled (events
# silently dropped, app keeps running).
SENTRY_LARAVEL_DSN=
# Identifies which deploy an event came from. Set this to the git
# SHA on each Railway deploy (Railway: $RAILWAY_GIT_COMMIT_SHA).
SENTRY_RELEASE=
# 'production' | 'staging' | 'development' — drives Sentry's
# environment grouping in the UI. Defaults to APP_ENV when empty.
SENTRY_ENVIRONMENT=
# Error sample rate. 1.0 = capture everything (default). Lower if we
# blow through Sentry's free-tier 5k/month quota.
SENTRY_SAMPLE_RATE=1.0
# Performance traces. null/empty = OFF. Tracing burns 10-100x more
# events than error capture. Turn on (e.g. 0.1) only when actively
# debugging perf, then turn back off.
SENTRY_TRACES_SAMPLE_RATE=

# ─── Database SSL ─────────────────────────────────────────────────
DB_SSLMODE=prefer

VITE_APP_NAME="${APP_NAME}"
